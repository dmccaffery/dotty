.SH NAME
dotty-brewfile-edit - Open the Brewfile in the default editor.


.SH SYNOPSIS
\fBdotty brewfile edit [--sync | --upgrade] [flags]\fP


.SH DESCRIPTION
Open the Brewfile in $VISUAL / $EDITOR. With --sync or --upgrade, the
corresponding command runs after the editor exits.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for edit

.PP
\fB--sync\fP[=false]
	run \fBdotty brewfile sync\fR after editing

.PP
\fB--upgrade\fP[=false]
	run \fBdotty brewfile upgrade\fR after editing


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	profile to operate on (defaults to the active profile)


.SH EXAMPLE
.EX
  dotty brewfile edit
  dotty brewfile edit --sync
.EE


.SH SEE ALSO
\fBdotty-brewfile(1)\fP
