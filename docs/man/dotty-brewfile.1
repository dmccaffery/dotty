.SH NAME
dotty-brewfile - Manage the profile's Brewfile for reproducible brews.


.SH SYNOPSIS
\fBdotty brewfile  [flags]\fP


.SH DESCRIPTION
Maintain a homebrew bundle Brewfile so a machine's brews stay reproducible
on and across systems. Commands operate on the active profile's Brewfile, or
on a specific profile's via the global --profile flag.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for brewfile


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	profile to operate on (defaults to the active profile)


.SH EXAMPLE
.EX
  dotty brewfile add ripgrep
  dotty brewfile add --cask ghostty
  dotty --profile=work brewfile sync
  dotty brew upgrade
.EE


.SH SEE ALSO
\fBdotty(1)\fP, \fBdotty-brewfile-add(1)\fP, \fBdotty-brewfile-dump(1)\fP, \fBdotty-brewfile-edit(1)\fP, \fBdotty-brewfile-sync(1)\fP, \fBdotty-brewfile-upgrade(1)\fP
