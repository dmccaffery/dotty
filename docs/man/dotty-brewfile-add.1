.SH NAME
dotty-brewfile-add - Add brews to the Brewfile and install them.


.SH SYNOPSIS
\fBdotty brewfile add [--tap | --cask | --formula | ...]  [...] [flags]\fP


.SH DESCRIPTION
Add one or more entries to the Brewfile, then install the bundle. Entries
default to formulae; pass a type flag for anything else. Tap-qualified names
(more than one slash) of formulae, casks, and taps go through Homebrew's
trust gate first — dotty asks before trusting anything new.


.SH OPTIONS
\fB--cargo\fP[=false]
	add Cargo packages

.PP
\fB--cask\fP[=false]
	add casks

.PP
\fB--flatpak\fP[=false]
	add Flatpak packages

.PP
\fB--formula\fP[=false]
	add formulae (the default)

.PP
\fB--go\fP[=false]
	add Go packages

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for add

.PP
\fB--krew\fP[=false]
	add Krew plugins

.PP
\fB--npm\fP[=false]
	add npm packages

.PP
\fB--tap\fP[=false]
	add taps

.PP
\fB--uv\fP[=false]
	add uv tools

.PP
\fB--vscode\fP[=false]
	add VSCode extensions


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	profile to operate on (defaults to the active profile)


.SH EXAMPLE
.EX
  dotty brewfile add ripgrep jq
  dotty brewfile add --cask ghostty
  dotty brewfile add --tap fluxcd/tap
  dotty brewfile add acme/tap/widget
.EE


