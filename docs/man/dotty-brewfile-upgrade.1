.SH NAME
dotty-brewfile-upgrade - Upgrade everything in the Brewfile.


.SH SYNOPSIS
\fBdotty brewfile upgrade [flags]\fP


.SH DESCRIPTION
Install and upgrade all brews in the Brewfile without removing anything —
brew bundle install --upgrade.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for upgrade


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	profile to operate on (defaults to the active profile)


.SH EXAMPLE
.EX
  dotty brewfile upgrade
  dotty --profile=work brewfile upgrade
.EE


.SH SEE ALSO
\fBdotty-brewfile(1)\fP
